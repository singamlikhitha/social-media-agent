# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_agent

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Token Encryption (generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())")
TOKEN_ENCRYPTION_KEY=

# Meta (Instagram + Facebook) OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/oauth/meta/callback

# Google (YouTube) OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# Twitter/X OAuth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3000/oauth/twitter/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
FRONTEND_URL=http://localhost:3000

# Scheduler
TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
